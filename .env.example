# Microsoft Azure - Mesh Daily Digest (Single Tenant)
AZURE_CLIENT_ID=your_application_client_id
AZURE_CLIENT_SECRET=your_client_secret_value
AZURE_TENANT_ID=your_directory_tenant_id

# Slack App
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=your_slack_bot_token

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Clerk
CLERK_SECRET_KEY=your_clerk_secret_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/meshsuture_digest

# Redis
REDIS_URL=redis://localhost:6379

# Token Encryption
TOKEN_ENCRYPTION_KEY=generate_a_64_char_hex_string_using_openssl_rand_hex_32

# App URL (used for OAuth redirect URIs and CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://dailydigest.meshsuture.com
